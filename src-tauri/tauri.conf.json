{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DayNeko",
  "version": "0.1.0",
  "identifier": "app.dayneko.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DayNeko",
        "width": 1200,
        "height": 640,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFCNjc3MjA1RThDNTE5NApSV1NVVVl4ZUlIZTJDa3RsMDJwZlJiblI5U2hEYnJLRHJSbGJVZllUbUlnem9VNVJLbDZzd2NHeQo=",
      "endpoints": [
        "https://github.com/Summer-Neko/DayNeko/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
